# Database (Postgres — local Prisma dev or Neon/Supabase in prod)
DATABASE_URL="postgresql://user:password@localhost:5432/ats_db"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/ats_db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Stripe (optional — billing is gated until set)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Tiered per-seat prices. Solo = $15/seat (1 seat), Team = $19/seat (2–10 seats).
STRIPE_PRICE_ID_SOLO="price_..."
STRIPE_PRICE_ID_TEAM="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Vercel Blob (auto-injected on Vercel once Blob storage is enabled)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Resend (transactional email)
RESEND_API_KEY="re_..."
EMAIL_FROM="onboarding@resend.dev"

# Google OAuth — used for sign-in AND the Google Calendar integration
# (lib/google-calendar.ts). Add /api/integrations/google/callback as
# a redirect URI in the Google Cloud console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft (Azure AD) — used for the Outlook Calendar + Teams
# integration (lib/microsoft-calendar.ts).
# Setup steps:
#   1. portal.azure.com → Azure AD → App registrations → New registration
#      Account types: "Accounts in any organizational directory and personal Microsoft accounts"
#   2. Redirect URI: <NEXTAUTH_URL>/api/integrations/microsoft/callback
#   3. API permissions (delegated): Calendars.ReadWrite, OnlineMeetings.ReadWrite
#   4. Certificates & secrets → New client secret → copy the value
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
