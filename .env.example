# Database (Postgres — local Prisma dev or Neon/Supabase in prod)
DATABASE_URL="postgresql://user:password@localhost:5432/ats_db"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/ats_db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Stripe (optional — billing is gated until set)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Tiered per-seat prices. Solo = $15/seat (1 seat), Team = $19/seat (2–10 seats).
STRIPE_PRICE_ID_SOLO="price_..."
STRIPE_PRICE_ID_TEAM="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Vercel Blob (auto-injected on Vercel once Blob storage is enabled)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Resend (transactional email)
RESEND_API_KEY="re_..."
EMAIL_FROM="onboarding@resend.dev"

# Outbound-mail safety rails for non-production environments.
# - DISABLE_OUTBOUND_EMAIL=1 → drop every send (no email goes out at
#   all). Use on staging/preview while we're still testing flows that
#   could trigger mail to real client addresses.
# - EMAIL_ALLOWLIST=you@x,colleague@y → only these addresses receive
#   mail; everything else is dropped with a log. Use if you want to
#   test with your own inbox without risking a client contact.
# Leave both unset in production.
# DISABLE_OUTBOUND_EMAIL=1
# EMAIL_ALLOWLIST=""

# Google OAuth — used for sign-in AND the Google Calendar integration
# (lib/google-calendar.ts). Add /api/integrations/google/callback as
# a redirect URI in the Google Cloud console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft (Azure AD) — used for the Outlook Calendar + Teams
# integration (lib/microsoft-calendar.ts).
# Setup steps:
#   1. portal.azure.com → Azure AD → App registrations → New registration
#      Account types: "Accounts in any organizational directory and personal Microsoft accounts"
#   2. Redirect URI: <NEXTAUTH_URL>/api/integrations/microsoft/callback
#   3. API permissions (delegated): Calendars.ReadWrite, OnlineMeetings.ReadWrite
#   4. Certificates & secrets → New client secret → copy the value
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""

# Sentry — error monitoring. Get the DSN from sentry.io → Project Settings → Client Keys.
# Leave SENTRY_DSN unset locally and Sentry stays silent. To smoke-test
# against a real project from `next dev`, set SENTRY_ENABLE_DEV=1.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Optional: 0..1 perf-traces sample rate. Default 0.1 (10%).
# SENTRY_TRACES_SAMPLE_RATE="0.1"
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
# Optional: turn on browser Session Replay (more $$, off by default).
# NEXT_PUBLIC_SENTRY_REPLAY="1"
# Build-time source-map upload (set in Vercel project env vars; leave
# unset locally to skip the upload step in `next build`).
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
