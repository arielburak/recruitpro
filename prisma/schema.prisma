generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── MULTI-TENANCY ───

// One per real human. Holds the authentication primitives (email,
// password, verification state) that used to be duplicated on User
// and ClientUser. A single Account can have N memberships: agency-
// side (User rows pointing at an Organization) and/or client-side
// (ClientUser rows pointing at a Client). That solves two problems:
//
//   1. The same person can be a recruiter at one firm AND a hiring
//      contact at another (or even at the same firm, when the agency
//      also hires for itself). Today that requires duplicate logins.
//
//   2. The same hiring contact can sit at multiple Clients. Today
//      ClientUser.email is globally unique, so we error out on the
//      second invite. With Account in the middle, the second invite
//      just adds another ClientUser membership.
//
// This PR introduces the model and backfills 1:1. Auth, login flow
// and the smart-invite paths follow in separate PRs so each step is
// reversible.
model Account {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  // Verification state — moved over from the two old tables. Email-
  // password signups land with token + expiry set; verifiedAt is set
  // once they click. OAuth (Google) and invite-via-set-password flows
  // backfill verifiedAt directly because the email is already proven.
  emailVerifiedAt            DateTime?
  emailVerificationToken     String?   @unique
  emailVerificationExpiresAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users       User[]
  clientUsers ClientUser[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  industry  String?
  companySize String?
  needsOnboarding Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  clients      Client[]
  // Hiring companies this agency is engaged with (decoupled from
  // Client.organizationId so the same hiring company can be worked
  // on by multiple agencies). See OrganizationClient.
  clientEngagements OrganizationClient[]
  candidates   Candidate[]
  contacts     Contact[]
  jobs         Job[]
  placements   Placement[]
  subscription Subscription?
  activities   Activity[]
  engagements  FirmEngagement[]
  interviews   Interview[]
  calendarEvents CalendarEvent[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  title          String?
  passwordHash   String
  role           UserRole @default(USER)
  avatar         String?
  isActive       Boolean  @default(true)
  // Email verification. Email/password signups land with all three
  // nullable: verifiedAt becomes a timestamp once the token in the
  // verification email is clicked. Google OAuth users skip the email
  // round-trip — we set verifiedAt at user-creation time because
  // Google has already verified the address. Token + expiry are
  // cleared on success.
  emailVerifiedAt            DateTime?
  emailVerificationToken     String?   @unique
  emailVerificationExpiresAt DateTime?
  // Link to the unified Account. Nullable while we migrate — the
  // backfill script in scripts/migrate-account-identity.ts populates
  // every existing row. Future PRs make this non-null and migrate
  // password / verification reads to the Account side.
  accountId      String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account               Account?              @relation(fields: [accountId], references: [id])
  organization          Organization          @relation(fields: [organizationId], references: [id])
  candidates            Candidate[]
  submissions           CandidateSubmission[] @relation("SubmittedBy")
  comments              Comment[]
  activities            Activity[]
  jobAssignments        JobAssignment[]
  createdInterviews     Interview[]           @relation("InterviewCreator")
  interviewAssignments  InterviewAssignment[]
  interviewFeedback     InterviewFeedback[]
  integrations          UserIntegration[]
  notifications         UserNotification[]
  firmEngagements       FirmEngagement[]      @relation("InvitedUser")
  createdCalendarEvents CalendarEvent[]       @relation("CalendarEventCreator")

  @@index([organizationId])
  @@index([accountId])
}

// In-app notifications for staffing users (one per user, personal inbox).
// Mirrors ClientNotification on the client side.
model UserNotification {
  id           String    @id @default(cuid())
  userId       String
  type         String    // "comment_posted" | "mention" | "candidate_shared" | ...
  title        String
  body         String?
  link         String?
  submissionId String?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model UserIntegration {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // "google_calendar" | "microsoft_teams"
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  email        String?  // connected account email
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

enum UserRole {
  ADMIN
  USER
}

// ─── CLIENTS (Hiring Companies) ───

model Client {
  id             String   @id @default(cuid())
  name           String
  industry       String?
  website        String?
  logo           String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  notes          String?
  // Engagement model with this client. "RECRUITING" = traditional
  // headhunting with fee + guarantee + payment terms (the defaults
  // below). "STAFF_AUG" = outsourcing / staff augmentation where
  // every search negotiates its own economics — we skip the defaults
  // entirely in that mode. Defaults to RECRUITING so pre-existing
  // clients stay on the current form.
  engagementType      String   @default("RECRUITING")
  defaultCurrency     String?  @default("USD")
  defaultFeeType      String?  @default("PERCENTAGE")
  defaultFeeAmount    Decimal?
  // Default invoice payment terms in days (e.g. 30 = "Net 30"). Used as the
  // pre-filled value when creating a placement for this client.
  defaultPaymentTerms Int?     @default(30)
  // Default guarantee period in days (e.g. 90 = three-month guarantee). The
  // recruiter agrees this once with the client and it pre-fills every
  // placement form for jobs at this client.
  defaultGuaranteePeriod Int?  @default(90)
  isOffLimits    Boolean  @default(false)
  bdStatus       String?
  // True when the Client was created via the quick-share flow on Job /new
  // (just an email, no real company info). The invited hiring manager
  // enriches name / industry on first login, which clears this flag.
  isStub         Boolean  @default(false)
  // organizationId is kept as audit metadata ("created by this org")
  // but is NOT the authoritative ownership signal anymore. A real-
  // world hiring company exists once in the DB and multiple agencies
  // can engage with it concurrently — see OrganizationClient. New
  // agency-side queries filter by the OrganizationClient join, not
  // by this column.
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  jobs         Job[]
  clientUsers  ClientUser[]
  contacts     Contact[]
  placements   Placement[]
  documents    Document[]
  portalTokens ClientPortalToken[]
  clientJobs   ClientJob[]
  pipelineStages ClientPipelineStage[]
  notifications  ClientNotification[]
  // Agencies engaged with this hiring company. One Client can be
  // worked on by multiple agencies in parallel — each agency only
  // sees their OWN Jobs at the client (Job.organizationId scope)
  // and the ClientJobs the client explicitly shared (FirmEngagement).
  engagedOrganizations OrganizationClient[]
  calendarEvents       CalendarEvent[]

  @@index([organizationId])
}

// Join between an agency Organization and a hiring-company Client.
// Models the "which agencies work with this client" relationship.
// Listing/access on the agency side filters via this join instead of
// Client.organizationId — that way a hiring company (e.g. Acme) lives
// once in the DB and any agency can engage with it without the system
// duplicating the Client record.
model OrganizationClient {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String
  addedAt        DateTime @default(now())
  // Foreign-system identifier the agency used for this Client (e.g.
  // OpenCATS company_id). Lets a bulk-import re-wire pipeline rows
  // back to the right Client even when several Clients in the
  // workspace share a name.
  externalId     String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([organizationId, clientId])
  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@index([clientId])
}

// ─── CONTACTS (people at hiring companies) ───

model Contact {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  title          String?
  email          String?
  phone          String?
  linkedIn       String?
  isPrimary      Boolean  @default(false)
  notes          String?
  clientId       String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  jobs         Job[]        @relation("HiringManager")
  interviews   InterviewClientContact[]

  @@index([clientId])
  @@index([organizationId])
}

model ClientUser {
  id           String   @id @default(cuid())
  // Globally unique today. Will be removed in a follow-up PR once
  // every read path goes through Account — at that point the same
  // email can have ClientUser memberships at multiple Clients, since
  // identity lives on Account and ClientUser becomes purely a
  // (account, client, role) link.
  email        String   @unique
  name         String
  title        String?
  passwordHash String?
  role         UserRole @default(USER)
  clientId     String
  isActive     Boolean  @default(true)
  // Email verification mirrors User: token + expiry are populated at
  // self-signup time and cleared on verify. The invited path
  // (set-password via mail token) and OAuth backfill emailVerifiedAt
  // at first activation since the email itself is proof of ownership.
  emailVerifiedAt            DateTime?
  emailVerificationToken     String?   @unique
  emailVerificationExpiresAt DateTime?
  // Link to the unified Account. Nullable while we migrate. See User.accountId.
  accountId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account    Account?          @relation(fields: [accountId], references: [id])
  client     Client            @relation(fields: [clientId], references: [id])
  comments   Comment[]
  ratings    CandidateRating[]
  clientJobs ClientJob[]
  notifications ClientNotification[]
  // Per-JO access — the JOs this team member was explicitly added to.
  // See ClientJobMember; combined with role=ADMIN as a global bypass.
  jobMemberships ClientJobMember[]

  @@index([clientId])
  @@index([accountId])
}

model ClientPortalToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  jobId     String?
  clientId  String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([token])
  @@index([clientId])
}

// ─── CANDIDATES ───

model Candidate {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  linkedIn       String?
  location       String?
  currentTitle   String?
  currentCompany String?
  currentSalary  Decimal?
  desiredSalary  Decimal?
  salaryCurrency String   @default("USD")
  skills         String[] @default([])
  summary        String?
  source         String?
  isOffLimits    Boolean  @default(false)
  tags           String[] @default([])
  // Foreign-system identifier (e.g. OpenCATS candidate_id) used by
  // bulk imports to re-wire candidate↔job pipeline rows. Optional;
  // when set, it's unique per organization so a follow-up import can
  // resolve "the same OpenCATS row" reliably.
  externalId     String?
  organizationId String
  ownerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id])
  owner        User                  @relation(fields: [ownerId], references: [id])
  submissions  CandidateSubmission[]
  documents    Document[]
  comments     Comment[]             @relation("CandidateComments")
  activities   Activity[]            @relation("CandidateActivities")
  interviews   Interview[]
  calendarEvents CalendarEvent[]

  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@index([ownerId])
  @@index([organizationId, lastName, firstName])
}

// ─── JOBS / SEARCHES ───

model Job {
  id             String    @id @default(cuid())
  title          String
  description    String?
  // Free-form recruiter notes scoped to this Job. Agency-side only —
  // the client portal has its own ClientJob.notes that doesn't sync
  // here, so an "HM has a side commission" note stays internal to
  // the firm.
  notes          String?
  status         JobStatus @default(OPEN)
  // Number of seats the client signed for on this search. The
  // placement flow uses it to decide when to auto-flip status to
  // FILLED: a single-seat job goes to FILLED as soon as one
  // placement is created, while multi-seat jobs stay Active until
  // every seat is placed. Defaults to 1 — the typical agency search.
  openings       Int       @default(1)
  currency       String    @default("USD")
  feeType        FeeType   @default(PERCENTAGE)
  feeAmount      Decimal?
  // Optional per-job override of the client's defaultPaymentTerms /
  // defaultGuaranteePeriod. Used heavily for Staff Aug clients where
  // every search negotiates its own terms (client.default* are null).
  // Recruiting jobs usually leave these null and inherit from the
  // client. Placement fallback chain: job.* ?? client.default*.
  paymentTerms   Int?
  guaranteePeriod Int?
  salary         String?
  location       String?
  workMode       String    @default("ON_SITE")
  clientId         String
  hiringManagerId  String?
  organizationId   String
  // Foreign-system identifier (e.g. OpenCATS joborder_id). Same shape
  // and purpose as Candidate.externalId — bulk-imports use it to
  // resolve pipeline rows to the right Job.
  externalId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  client         Client              @relation(fields: [clientId], references: [id])
  hiringManager  Contact?            @relation("HiringManager", fields: [hiringManagerId], references: [id])
  organization   Organization        @relation(fields: [organizationId], references: [id])
  stages         PipelineStage[]
  submissions    CandidateSubmission[]
  comments       Comment[]           @relation("JobComments")
  assignments    JobAssignment[]
  placements     Placement[]
  documents      Document[]
  interviews     Interview[]
  calendarEvents CalendarEvent[]
  // Populated when the Job was born out of a client-portal invite. Used
  // to enforce person-level privacy on Job visibility — if any of the
  // linked engagements has invitedUserId set, only the assignees see
  // the Job (admins included).
  firmEngagements FirmEngagement[]
  // Mirror row created in the client portal when the recruiter uses
  // "Invite Client" from /jobs/[id]. The client sees this in their
  // portal but can't edit it — the agency owns the source of truth.
  clientJobMirror ClientJob? @relation("ClientJobMirror")

  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@index([clientId])
  @@index([organizationId, status])
}

enum JobStatus {
  OPEN
  ACTIVE
  ON_HOLD
  FILLED
  CANCELLED
  LOST
  // Kept only so legacy rows that still have CLOSED type-check.
  // New saves can't write it (see lib/validations/job.ts and the
  // PATCH allowlist) — recruiters flip legacy CLOSED rows to one
  // of the active statuses via the inline dropdown on /jobs.
  CLOSED
}

enum FeeType {
  PERCENTAGE
  FLAT
}

model JobAssignment {
  id     String @id @default(cuid())
  jobId  String
  userId String

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
}

// ─── PIPELINE ───

model PipelineStage {
  id         String  @id @default(cuid())
  name       String
  order      Int
  color      String  @default("#6366f1")
  isTerminal Boolean @default(false)
  kind       String? // "positive" | "negative" | null
  jobId      String

  job         Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  submissions CandidateSubmission[]

  @@unique([jobId, order])
  @@index([jobId])
}

// Client-owned pipeline stages — independent from recruiter's PipelineStage.
// One set per Client (company-wide, not per-job). Default stages created on
// client creation: Under Review, Interviewing, Offered, Placed, Lost, Rejected.
model ClientPipelineStage {
  id         String   @id @default(cuid())
  name       String
  order      Int
  color      String   @default("#f59e0b")
  isTerminal Boolean  @default(false)
  kind       String?  // Optional semantic: "positive" | "negative" | null
  clientId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client      Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  submissions CandidateSubmission[]

  @@unique([clientId, order])
  @@index([clientId])
}

// In-app notifications for the client portal.
// When `clientUserId` is set → visible to that specific user only.
// When `clientUserId` is null → visible to ALL client users of the company (company-wide notice).
model ClientNotification {
  id           String    @id @default(cuid())
  clientId     String
  clientUserId String?   // target user (null = company-wide)
  type         String    // "candidate_shared" | "candidate_stage_changed" | "comment_posted" | "mention" | ...
  title        String
  body         String?
  link         String?
  submissionId String?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientUser ClientUser? @relation(fields: [clientUserId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([clientId, readAt])
  @@index([clientUserId, readAt])
}

model CandidateSubmission {
  id                 String   @id @default(cuid())
  candidateId        String
  jobId              String
  stageId            String
  clientStageId      String?
  submittedBy        String
  notes              String?
  isSharedWithClient Boolean  @default(false)
  sharedAt           DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  candidate Candidate       @relation(fields: [candidateId], references: [id])
  job       Job             @relation(fields: [jobId], references: [id])
  stage     PipelineStage   @relation(fields: [stageId], references: [id])
  clientStage ClientPipelineStage? @relation(fields: [clientStageId], references: [id])
  submitter  User            @relation("SubmittedBy", fields: [submittedBy], references: [id])
  comments   Comment[]       @relation("SubmissionComments")
  ratings    CandidateRating[]
  placement  Placement?
  interviews Interview[]

  @@unique([candidateId, jobId])
  @@index([jobId, stageId])
  @@index([clientStageId])
}

model CandidateRating {
  id           String   @id @default(cuid())
  score        Int
  feedback     String?
  submissionId String
  clientUserId String
  createdAt    DateTime @default(now())

  submission CandidateSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  clientUser ClientUser          @relation(fields: [clientUserId], references: [id])

  @@unique([submissionId, clientUserId])
}

// ─── COMMENTS ───

model Comment {
  id           String      @id @default(cuid())
  content      String
  type         CommentType @default(INTERNAL)
  mentions     String[]    @default([])
  candidateId  String?
  submissionId String?
  // Job-level notes — the chat-style thread on /jobs/[id] (no
  // submission required). Lets the recruiter capture standing
  // observations about a search ("HM cobra una comisión", "salary
  // cap real es 180k", etc.) with authorship + timestamps + mentions.
  jobId        String?
  // ClientJob-level notes — the chat-style thread on the client
  // portal job page. Private to the hiring company's team and never
  // synced to the agency side (those have their own Job.notes /
  // jobId thread). CommentType is always CLIENT_INTERNAL here.
  clientJobId  String?
  userId       String?
  clientUserId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  candidate  Candidate?            @relation("CandidateComments", fields: [candidateId], references: [id])
  submission CandidateSubmission?  @relation("SubmissionComments", fields: [submissionId], references: [id])
  job        Job?                  @relation("JobComments", fields: [jobId], references: [id])
  clientJob  ClientJob?            @relation("ClientJobComments", fields: [clientJobId], references: [id])
  user       User?                 @relation(fields: [userId], references: [id])
  clientUser ClientUser?           @relation(fields: [clientUserId], references: [id])

  @@index([candidateId])
  @@index([submissionId])
  @@index([jobId])
  @@index([clientJobId])
}

enum CommentType {
  INTERNAL         // staffing-firm internal, not visible to client
  CLIENT_VISIBLE   // shared between staffing + client
  CLIENT_INTERNAL  // client-team internal, not visible to staffing firm
}

// ─── INTERVIEWS ───

model Interview {
  id             String          @id @default(cuid())
  title          String
  startTime      DateTime
  endTime        DateTime
  type           InterviewType   @default(VIDEO)
  status         InterviewStatus @default(SCHEDULED)
  notes          String?
  meetingLink    String?
  location       String?
  timezone       String          @default("America/Argentina/Buenos_Aires")
  submissionId   String
  jobId          String
  candidateId    String
  organizationId String
  createdBy      String
  // Google Calendar integration — populated when the interview is
  // created with a Google Meet link. Used to PATCH the event later
  // (e.g. to add a new attendee if the candidate email changes).
  googleEventId          String?
  googleCalendarOwnerId  String?
  // Microsoft (Outlook + Teams) integration — same idea for Teams
  // meetings.
  microsoftEventId          String?
  microsoftCalendarOwnerId  String?
  // True iff the candidate was emailed a calendar invite for this
  // interview (the "Send calendar invite by email" checkbox was on
  // at create time AND the candidate had an email to receive it).
  // Backfilled false for pre-existing rows because we don't have a
  // historical record either way — better to under-report than to
  // claim we emailed candidates we didn't.
  inviteSent     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  submission   CandidateSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  job          Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate    Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  organization Organization        @relation(fields: [organizationId], references: [id])
  creator      User                @relation("InterviewCreator", fields: [createdBy], references: [id])
  interviewers    InterviewAssignment[]
  clientContacts  InterviewClientContact[]
  feedback        InterviewFeedback[]
  // Attachments uploaded against the interview (agenda, prep doc,
  // NDA, etc.). Cascade-deleted with the interview.
  documents       Document[]

  @@index([organizationId, startTime])
  @@index([candidateId])
  @@index([jobId])
  @@index([submissionId])
}

model InterviewAssignment {
  id          String @id @default(cuid())
  interviewId String
  userId      String

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([interviewId, userId])
}

model InterviewClientContact {
  id          String @id @default(cuid())
  interviewId String
  contactId   String

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([interviewId, contactId])
}

model InterviewFeedback {
  id           String   @id @default(cuid())
  interviewId  String
  type         String   @default("INTERNAL") // INTERNAL | CLIENT
  rating       Int?     // 1-5 star rating
  comment      String   @db.Text
  authorName   String   // For client feedback (no user account needed)
  userId       String?  // Null for client feedback
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([interviewId])
}

enum InterviewType {
  PHONE
  VIDEO
  IN_PERSON
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─── DOCUMENTS ───

model Document {
  id           String   @id @default(cuid())
  name         String
  url          String
  type         String
  size         Int
  category     String?
  candidateId  String?
  jobId        String?
  clientJobId  String?
  clientId     String?
  // Attachments on a scheduled interview (think Outlook-style invite
  // attachments: agenda, prep doc, NDA, JD reference). Null for
  // documents pinned to candidates / jobs / clients.
  interviewId  String?
  uploadedBy   String
  createdAt    DateTime @default(now())

  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job?       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  clientJob ClientJob? @relation(fields: [clientJobId], references: [id], onDelete: Cascade)
  client    Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  interview Interview? @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([jobId])
  @@index([clientJobId])
  @@index([clientId])
  @@index([interviewId])
}

// ─── ACTIVITIES ───

model Activity {
  id             String   @id @default(cuid())
  action         String
  description    String
  metadata       Json     @default("{}")
  userId         String?
  candidateId    String?
  organizationId String
  createdAt      DateTime @default(now())

  user         User?        @relation(fields: [userId], references: [id])
  candidate    Candidate?   @relation("CandidateActivities", fields: [candidateId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([candidateId])
}

// ─── PLACEMENTS ───

model Placement {
  id                  String          @id @default(cuid())
  // estimatedStartDate is what the recruiter/candidate negotiated up front.
  // startDate is the confirmed start once the candidate actually shows up.
  estimatedStartDate  DateTime?
  startDate           DateTime?
  // What flavour of engagement this placement records. "HH" = headhunting
  // / contingent recruiting: one-time fee on hire (the historical default,
  // and what every existing row is). "OS" = outsourcing / staff aug: the
  // candidate stays on the agency's payroll and we bill the client a
  // recurring monthlyFee. Different fields are meaningful per kind:
  //   - HH  → feeAmount / feePercentage / paymentTerms / guaranteePeriod
  //   - OS  → monthlyFee / endDate (null = still active)
  // The form pre-picks `kind` from Client.engagementType (RECRUITING → HH;
  // STAFF_AUG → OS) and the create API rejects mixed payloads so an OS
  // row can't accidentally get a giant flat feeAmount.
  kind                String          @default("HH")
  monthlyFee          Decimal?
  // When the OS engagement ended (left, contract over, etc.). null on
  // HH placements and on active OS engagements. Used to compute MRR
  // (active when null) and to bound revenue accrual per period.
  endDate             DateTime?
  feeAmount           Decimal?
  feePercentage       Decimal?
  salary              Decimal?
  // Optional currency override. Falls back to job.currency at display time
  // when null — most placements just inherit the search's currency, but
  // we keep this column so a placement closed in a different currency
  // (e.g. ARS contract on a USD-default client) can be represented
  // faithfully without rewriting the job.
  currency            String?
  // How to interpret the `salary` value. Recruiting fees are always
  // calculated against the candidate's ANNUAL salary, but recruiters in
  // some markets (LATAM especially) quote and store the salary as a
  // monthly figure. When MONTHLY, the fee calc multiplies by 12 before
  // applying the percentage. Default ANNUAL keeps the US-friendly path.
  salaryPeriod        String?         @default("ANNUAL")
  // Gross vs net interpretation of the `salary` value. Argentina (and
  // a few other LATAM markets) quotes either depending on context —
  // candidates often negotiate take-home (NET), employers think in
  // gross. Recruiting fees are calculated against the GROSS figure,
  // so when NET is stored we convert via the AR payroll ratio
  // (~17% worker contributions → gross = net / 0.83) at fee-calc
  // time. Default BRUTO keeps the US-friendly path.
  salaryKind          SalaryKind      @default(BRUTO)
  // paymentTerms is the number of days between startDate (or estimated)
  // and when the agency expects to be paid. paymentDueDate is the
  // resolved date — kept on the row so reporting doesn't have to compute it.
  paymentTerms        Int?
  paymentDueDate      DateTime?
  invoiceStatus       InvoiceStatus   @default(DRAFT)
  guaranteePeriod     Int?            @default(90)
  guaranteeExpiry     DateTime?
  notes               String?
  submissionId        String?         @unique
  jobId               String
  clientId            String
  organizationId      String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  submission   CandidateSubmission? @relation(fields: [submissionId], references: [id])
  job          Job                  @relation(fields: [jobId], references: [id])
  client       Client               @relation(fields: [clientId], references: [id])
  organization Organization         @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, createdAt(sort: Desc)])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

enum SalaryKind {
  BRUTO   // gross — what the employer pays before payroll deductions
  NETO    // net — what the candidate takes home after worker contributions
}

// ─── CLIENT JOBS (posted by clients directly) ───

model ClientJob {
  id             String   @id @default(cuid())
  title          String
  description    String?
  requirements   String?
  // Free-form notes from the client-portal side. Strictly private to
  // the hiring company — Job.notes on the agency side never syncs
  // back, so the client can keep "HM is impossible to schedule with"
  // observations without leaking to the firms they engage.
  notes          String?
  location       String?
  salaryRange    String?
  salaryCurrency String   @default("USD")
  jobType        String   @default("Full-time")
  isRemote     Boolean  @default(false)
  status       String   @default("OPEN")
  clientId     String
  postedById   String
  // True when the row was mirrored over from an agency-side Job via
  // the "Invite Client" flow on /jobs/[id]. The client sees the search
  // in their portal but can't edit description / requirements /
  // documents — the agency owns the source of truth. Notes (chat) and
  // team management stay editable because those are about how the
  // client team collaborates around the search, not about the search
  // itself.
  createdByAgency Boolean @default(false)
  // FK to the originating agency Job when createdByAgency is true.
  // Nullable + onDelete: SetNull so deleting the agency Job leaves the
  // client's view of the engagement intact instead of cascading.
  sourceJobId    String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client             Client              @relation(fields: [clientId], references: [id])
  postedBy           ClientUser          @relation(fields: [postedById], references: [id])
  sourceJob          Job?                @relation("ClientJobMirror", fields: [sourceJobId], references: [id], onDelete: SetNull)
  engagements        FirmEngagement[]
  pendingFirmInvites PendingFirmInvite[]
  documents          Document[]
  // Per-JO member access: ClientUsers explicitly listed here can see
  // this job. If the array is empty, ALL team members of the Client
  // can see it (backwards-compatible default for jobs created before
  // this feature shipped). Admins always see everything regardless.
  members            ClientJobMember[]
  // Chat-style notes thread for the client team. Replaces the legacy
  // free-form `notes` string above; that field is kept for historical
  // rows and is backfilled into Comment rows on first migration.
  comments           Comment[]           @relation("ClientJobComments")

  @@index([clientId])
  @@index([status])
}

model ClientJobMember {
  id           String   @id @default(cuid())
  clientJobId  String
  clientUserId String
  addedAt      DateTime @default(now())

  clientJob  ClientJob  @relation(fields: [clientJobId], references: [id], onDelete: Cascade)
  clientUser ClientUser @relation(fields: [clientUserId], references: [id], onDelete: Cascade)

  @@unique([clientJobId, clientUserId])
  @@index([clientJobId])
  @@index([clientUserId])
}

// ─── FIRM ENGAGEMENTS (links client jobs to recruiting firms) ───

model FirmEngagement {
  id             String    @id @default(cuid())
  clientJobId    String
  organizationId String
  // Email of the SPECIFIC recruiter invited. Nullable because legacy
  // engagements (pre-person-level invites) only stored organizationId;
  // new rows always set this.
  invitedEmail   String?
  // User that claimed the invite. Set when the invited email matches an
  // existing User at invite time, or later when a PendingFirmInvite is
  // promoted to an engagement on login. Null for legacy rows.
  invitedUserId  String?
  status         String    @default("PENDING")
  message        String?
  jobId          String?
  invitedAt      DateTime  @default(now())
  respondedAt    DateTime?

  clientJob    ClientJob    @relation(fields: [clientJobId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  invitedUser  User?        @relation("InvitedUser", fields: [invitedUserId], references: [id])
  job          Job?         @relation(fields: [jobId], references: [id])

  // One invite per email per job. Legacy rows (null invitedEmail) are
  // exempt — Postgres treats NULLs as distinct — so the migration is safe.
  @@unique([clientJobId, invitedEmail])
  @@index([organizationId])
  @@index([invitedUserId])
  @@index([organizationId, status])
}

// ─── PENDING FIRM INVITES (email invites before firm registers) ───

model PendingFirmInvite {
  id          String   @id @default(cuid())
  email       String
  clientJobId String
  message     String?
  clientId    String
  createdAt   DateTime @default(now())

  clientJob ClientJob @relation(fields: [clientJobId], references: [id], onDelete: Cascade)

  @@index([email])
  @@unique([email, clientJobId])
}

// ─── BILLING ───

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  seats                Int                @default(1)
  // Complimentary / free-forever flag. Used for founding-team orgs,
  // partners, long-running test accounts — anyone we want to keep
  // unlocked without tying them to a Stripe subscription. When true,
  // subscription checks pass regardless of status/trial.
  isComp               Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

// ─── PASSWORD RESETS ───

model PasswordResetToken {
  id           String   @id @default(cuid())
  token        String   @unique
  userId       String?
  clientUserId String?
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([clientUserId])
  @@index([token])
}

// ─── INVITES ───

model UserInvite {
  id             String   @id @default(cuid())
  email          String
  name           String?
  token          String   @unique @default(cuid())
  role           UserRole @default(USER)
  organizationId String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([token])
  @@index([organizationId])
}

// ─── CALENDAR EVENTS ───
//
// Generic personal calendar events (Outlook / Google-style) that live
// alongside Interviews on the recruiter's /calendar grid. Use cases:
// follow-up reminders, internal team syncs, blocking time, "call so-
// and-so back next week" notes. Interviews stay their own model
// because they carry candidate / submission / feedback / external
// invite semantics; events deliberately don't — they're a personal
// block.
//
// Visibility is per-user: every event belongs to its creator and
// only the creator sees it. No invitee list, no email fan-out (the
// agency policy is "don't email the candidate from generic events"
// — Interviews are the only path that mails anyone).
//
// Optional relations are nullable on purpose so the same model
// handles:
//   - "FU with Acme" → clientId set
//   - "Touch base with John Doe" → candidateId set
//   - "Team weekly on Sales VP" → jobId set
//   - Pure personal block → none set
// Relations use onDelete: SetNull so dropping a Job / Candidate /
// Client doesn't nuke the recruiter's reminders alongside it.
model CalendarEvent {
  id             String   @id @default(cuid())
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  allDay         Boolean  @default(false)
  location       String?
  meetingLink    String?
  timezone       String   @default("America/Argentina/Buenos_Aires")
  // High-level kind for the chip color + icon. Free-form string instead
  // of an enum so we can iterate without a migration; the UI maps
  // unknown values to the neutral "EVENT" style.
  kind           String   @default("EVENT") // EVENT | FOLLOW_UP | REMINDER | MEETING

  clientId       String?
  candidateId    String?
  jobId          String?

  organizationId String
  createdBy      String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  candidate    Candidate?   @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  job          Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id])
  creator      User         @relation("CalendarEventCreator", fields: [createdBy], references: [id])

  @@index([organizationId, startTime])
  @@index([createdBy, startTime])
  @@index([clientId])
  @@index([candidateId])
  @@index([jobId])
}
