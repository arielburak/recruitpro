generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── MULTI-TENANCY ───

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  industry  String?
  companySize String?
  needsOnboarding Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  clients      Client[]
  candidates   Candidate[]
  contacts     Contact[]
  jobs         Job[]
  placements   Placement[]
  subscription Subscription?
  activities   Activity[]
  engagements  FirmEngagement[]
  interviews   Interview[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  title          String?
  passwordHash   String
  role           UserRole @default(USER)
  avatar         String?
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization          Organization          @relation(fields: [organizationId], references: [id])
  candidates            Candidate[]
  submissions           CandidateSubmission[] @relation("SubmittedBy")
  comments              Comment[]
  activities            Activity[]
  jobAssignments        JobAssignment[]
  createdInterviews     Interview[]           @relation("InterviewCreator")
  interviewAssignments  InterviewAssignment[]
  interviewFeedback     InterviewFeedback[]
  integrations          UserIntegration[]
  notifications         UserNotification[]
  firmEngagements       FirmEngagement[]      @relation("InvitedUser")

  @@index([organizationId])
}

// In-app notifications for staffing users (one per user, personal inbox).
// Mirrors ClientNotification on the client side.
model UserNotification {
  id           String    @id @default(cuid())
  userId       String
  type         String    // "comment_posted" | "mention" | "candidate_shared" | ...
  title        String
  body         String?
  link         String?
  submissionId String?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model UserIntegration {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // "google_calendar" | "microsoft_teams"
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  email        String?  // connected account email
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

enum UserRole {
  ADMIN
  USER
}

// ─── CLIENTS (Hiring Companies) ───

model Client {
  id             String   @id @default(cuid())
  name           String
  industry       String?
  website        String?
  logo           String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  notes          String?
  // Engagement model with this client. "RECRUITING" = traditional
  // headhunting with fee + guarantee + payment terms (the defaults
  // below). "STAFF_AUG" = outsourcing / staff augmentation where
  // every search negotiates its own economics — we skip the defaults
  // entirely in that mode. Defaults to RECRUITING so pre-existing
  // clients stay on the current form.
  engagementType      String   @default("RECRUITING")
  defaultCurrency     String?  @default("USD")
  defaultFeeType      String?  @default("PERCENTAGE")
  defaultFeeAmount    Decimal?
  // Default invoice payment terms in days (e.g. 30 = "Net 30"). Used as the
  // pre-filled value when creating a placement for this client.
  defaultPaymentTerms Int?     @default(30)
  // Default guarantee period in days (e.g. 90 = three-month guarantee). The
  // recruiter agrees this once with the client and it pre-fills every
  // placement form for jobs at this client.
  defaultGuaranteePeriod Int?  @default(90)
  isOffLimits    Boolean  @default(false)
  bdStatus       String?
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  jobs         Job[]
  clientUsers  ClientUser[]
  contacts     Contact[]
  placements   Placement[]
  documents    Document[]
  portalTokens ClientPortalToken[]
  clientJobs   ClientJob[]
  pipelineStages ClientPipelineStage[]
  notifications  ClientNotification[]

  @@index([organizationId])
}

// ─── CONTACTS (people at hiring companies) ───

model Contact {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  title          String?
  email          String?
  phone          String?
  linkedIn       String?
  isPrimary      Boolean  @default(false)
  notes          String?
  clientId       String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  jobs         Job[]        @relation("HiringManager")
  interviews   InterviewClientContact[]

  @@index([clientId])
  @@index([organizationId])
}

model ClientUser {
  id           String   @id @default(cuid())
  email        String
  name         String
  title        String?
  passwordHash String?
  role         UserRole @default(USER)
  clientId     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client     Client            @relation(fields: [clientId], references: [id])
  comments   Comment[]
  ratings    CandidateRating[]
  clientJobs ClientJob[]
  notifications ClientNotification[]

  @@unique([email, clientId])
  @@index([clientId])
}

model ClientPortalToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  jobId     String?
  clientId  String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([token])
  @@index([clientId])
}

// ─── CANDIDATES ───

model Candidate {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  linkedIn       String?
  location       String?
  currentTitle   String?
  currentCompany String?
  currentSalary  Decimal?
  desiredSalary  Decimal?
  salaryCurrency String   @default("USD")
  skills         String[] @default([])
  summary        String?
  source         String?
  isOffLimits    Boolean  @default(false)
  tags           String[] @default([])
  organizationId String
  ownerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id])
  owner        User                  @relation(fields: [ownerId], references: [id])
  submissions  CandidateSubmission[]
  documents    Document[]
  comments     Comment[]             @relation("CandidateComments")
  activities   Activity[]            @relation("CandidateActivities")
  interviews   Interview[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([organizationId, lastName, firstName])
}

// ─── JOBS / SEARCHES ───

model Job {
  id             String    @id @default(cuid())
  title          String
  description    String?
  status         JobStatus @default(OPEN)
  currency       String    @default("USD")
  feeType        FeeType   @default(PERCENTAGE)
  feeAmount      Decimal?
  // Optional per-job override of the client's defaultPaymentTerms /
  // defaultGuaranteePeriod. Used heavily for Staff Aug clients where
  // every search negotiates its own terms (client.default* are null).
  // Recruiting jobs usually leave these null and inherit from the
  // client. Placement fallback chain: job.* ?? client.default*.
  paymentTerms   Int?
  guaranteePeriod Int?
  salary         String?
  location       String?
  workMode       String    @default("ON_SITE")
  clientId         String
  hiringManagerId  String?
  organizationId   String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  client         Client              @relation(fields: [clientId], references: [id])
  hiringManager  Contact?            @relation("HiringManager", fields: [hiringManagerId], references: [id])
  organization   Organization        @relation(fields: [organizationId], references: [id])
  stages         PipelineStage[]
  submissions    CandidateSubmission[]
  assignments    JobAssignment[]
  placements     Placement[]
  documents      Document[]
  interviews     Interview[]
  // Populated when the Job was born out of a client-portal invite. Used
  // to enforce person-level privacy on Job visibility — if any of the
  // linked engagements has invitedUserId set, only the assignees see
  // the Job (admins included).
  firmEngagements FirmEngagement[]

  @@index([organizationId])
  @@index([clientId])
  @@index([organizationId, status])
}

enum JobStatus {
  OPEN
  ACTIVE
  ON_HOLD
  FILLED
  CLOSED
}

enum FeeType {
  PERCENTAGE
  FLAT
}

model JobAssignment {
  id     String @id @default(cuid())
  jobId  String
  userId String

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
}

// ─── PIPELINE ───

model PipelineStage {
  id         String  @id @default(cuid())
  name       String
  order      Int
  color      String  @default("#6366f1")
  isTerminal Boolean @default(false)
  kind       String? // "positive" | "negative" | null
  jobId      String

  job         Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  submissions CandidateSubmission[]

  @@unique([jobId, order])
  @@index([jobId])
}

// Client-owned pipeline stages — independent from recruiter's PipelineStage.
// One set per Client (company-wide, not per-job). Default stages created on
// client creation: Under Review, Interviewing, Offered, Placed, Lost, Rejected.
model ClientPipelineStage {
  id         String   @id @default(cuid())
  name       String
  order      Int
  color      String   @default("#f59e0b")
  isTerminal Boolean  @default(false)
  kind       String?  // Optional semantic: "positive" | "negative" | null
  clientId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client      Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  submissions CandidateSubmission[]

  @@unique([clientId, order])
  @@index([clientId])
}

// In-app notifications for the client portal.
// When `clientUserId` is set → visible to that specific user only.
// When `clientUserId` is null → visible to ALL client users of the company (company-wide notice).
model ClientNotification {
  id           String    @id @default(cuid())
  clientId     String
  clientUserId String?   // target user (null = company-wide)
  type         String    // "candidate_shared" | "candidate_stage_changed" | "comment_posted" | "mention" | ...
  title        String
  body         String?
  link         String?
  submissionId String?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientUser ClientUser? @relation(fields: [clientUserId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([clientId, readAt])
  @@index([clientUserId, readAt])
}

model CandidateSubmission {
  id                 String   @id @default(cuid())
  candidateId        String
  jobId              String
  stageId            String
  clientStageId      String?
  submittedBy        String
  notes              String?
  isSharedWithClient Boolean  @default(false)
  sharedAt           DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  candidate Candidate       @relation(fields: [candidateId], references: [id])
  job       Job             @relation(fields: [jobId], references: [id])
  stage     PipelineStage   @relation(fields: [stageId], references: [id])
  clientStage ClientPipelineStage? @relation(fields: [clientStageId], references: [id])
  submitter  User            @relation("SubmittedBy", fields: [submittedBy], references: [id])
  comments   Comment[]       @relation("SubmissionComments")
  ratings    CandidateRating[]
  placement  Placement?
  interviews Interview[]

  @@unique([candidateId, jobId])
  @@index([jobId, stageId])
  @@index([clientStageId])
}

model CandidateRating {
  id           String   @id @default(cuid())
  score        Int
  feedback     String?
  submissionId String
  clientUserId String
  createdAt    DateTime @default(now())

  submission CandidateSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  clientUser ClientUser          @relation(fields: [clientUserId], references: [id])

  @@unique([submissionId, clientUserId])
}

// ─── COMMENTS ───

model Comment {
  id           String      @id @default(cuid())
  content      String
  type         CommentType @default(INTERNAL)
  mentions     String[]    @default([])
  candidateId  String?
  submissionId String?
  userId       String?
  clientUserId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  candidate  Candidate?            @relation("CandidateComments", fields: [candidateId], references: [id])
  submission CandidateSubmission?  @relation("SubmissionComments", fields: [submissionId], references: [id])
  user       User?                 @relation(fields: [userId], references: [id])
  clientUser ClientUser?           @relation(fields: [clientUserId], references: [id])

  @@index([candidateId])
  @@index([submissionId])
}

enum CommentType {
  INTERNAL         // staffing-firm internal, not visible to client
  CLIENT_VISIBLE   // shared between staffing + client
  CLIENT_INTERNAL  // client-team internal, not visible to staffing firm
}

// ─── INTERVIEWS ───

model Interview {
  id             String          @id @default(cuid())
  title          String
  startTime      DateTime
  endTime        DateTime
  type           InterviewType   @default(VIDEO)
  status         InterviewStatus @default(SCHEDULED)
  notes          String?
  meetingLink    String?
  location       String?
  timezone       String          @default("America/Argentina/Buenos_Aires")
  submissionId   String
  jobId          String
  candidateId    String
  organizationId String
  createdBy      String
  // Google Calendar integration — populated when the interview is
  // created with a Google Meet link. Used to PATCH the event later
  // (e.g. to add a new attendee if the candidate email changes).
  googleEventId          String?
  googleCalendarOwnerId  String?
  // Microsoft (Outlook + Teams) integration — same idea for Teams
  // meetings.
  microsoftEventId          String?
  microsoftCalendarOwnerId  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  submission   CandidateSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  job          Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate    Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  organization Organization        @relation(fields: [organizationId], references: [id])
  creator      User                @relation("InterviewCreator", fields: [createdBy], references: [id])
  interviewers    InterviewAssignment[]
  clientContacts  InterviewClientContact[]
  feedback        InterviewFeedback[]

  @@index([organizationId, startTime])
  @@index([candidateId])
  @@index([jobId])
  @@index([submissionId])
}

model InterviewAssignment {
  id          String @id @default(cuid())
  interviewId String
  userId      String

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([interviewId, userId])
}

model InterviewClientContact {
  id          String @id @default(cuid())
  interviewId String
  contactId   String

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([interviewId, contactId])
}

model InterviewFeedback {
  id           String   @id @default(cuid())
  interviewId  String
  type         String   @default("INTERNAL") // INTERNAL | CLIENT
  rating       Int?     // 1-5 star rating
  comment      String   @db.Text
  authorName   String   // For client feedback (no user account needed)
  userId       String?  // Null for client feedback
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([interviewId])
}

enum InterviewType {
  PHONE
  VIDEO
  IN_PERSON
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─── DOCUMENTS ───

model Document {
  id           String   @id @default(cuid())
  name         String
  url          String
  type         String
  size         Int
  category     String?
  candidateId  String?
  jobId        String?
  clientJobId  String?
  clientId     String?
  uploadedBy   String
  createdAt    DateTime @default(now())

  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job?       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  clientJob ClientJob? @relation(fields: [clientJobId], references: [id], onDelete: Cascade)
  client    Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([jobId])
  @@index([clientJobId])
  @@index([clientId])
}

// ─── ACTIVITIES ───

model Activity {
  id             String   @id @default(cuid())
  action         String
  description    String
  metadata       Json     @default("{}")
  userId         String?
  candidateId    String?
  organizationId String
  createdAt      DateTime @default(now())

  user         User?        @relation(fields: [userId], references: [id])
  candidate    Candidate?   @relation("CandidateActivities", fields: [candidateId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([candidateId])
}

// ─── PLACEMENTS ───

model Placement {
  id                  String          @id @default(cuid())
  // estimatedStartDate is what the recruiter/candidate negotiated up front.
  // startDate is the confirmed start once the candidate actually shows up.
  estimatedStartDate  DateTime?
  startDate           DateTime?
  feeAmount           Decimal?
  feePercentage       Decimal?
  salary              Decimal?
  // Optional currency override. Falls back to job.currency at display time
  // when null — most placements just inherit the search's currency, but
  // we keep this column so a placement closed in a different currency
  // (e.g. ARS contract on a USD-default client) can be represented
  // faithfully without rewriting the job.
  currency            String?
  // paymentTerms is the number of days between startDate (or estimated)
  // and when the agency expects to be paid. paymentDueDate is the
  // resolved date — kept on the row so reporting doesn't have to compute it.
  paymentTerms        Int?
  paymentDueDate      DateTime?
  invoiceStatus       InvoiceStatus   @default(DRAFT)
  guaranteePeriod     Int?            @default(90)
  guaranteeExpiry     DateTime?
  notes               String?
  submissionId        String?         @unique
  jobId               String
  clientId            String
  organizationId      String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  submission   CandidateSubmission? @relation(fields: [submissionId], references: [id])
  job          Job                  @relation(fields: [jobId], references: [id])
  client       Client               @relation(fields: [clientId], references: [id])
  organization Organization         @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, createdAt(sort: Desc)])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

// ─── CLIENT JOBS (posted by clients directly) ───

model ClientJob {
  id             String   @id @default(cuid())
  title          String
  description    String?
  requirements   String?
  location       String?
  salaryRange    String?
  salaryCurrency String   @default("USD")
  jobType        String   @default("Full-time")
  isRemote     Boolean  @default(false)
  status       String   @default("OPEN")
  clientId     String
  postedById   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client             Client              @relation(fields: [clientId], references: [id])
  postedBy           ClientUser          @relation(fields: [postedById], references: [id])
  engagements        FirmEngagement[]
  pendingFirmInvites PendingFirmInvite[]
  documents          Document[]

  @@index([clientId])
  @@index([status])
}

// ─── FIRM ENGAGEMENTS (links client jobs to recruiting firms) ───

model FirmEngagement {
  id             String    @id @default(cuid())
  clientJobId    String
  organizationId String
  // Email of the SPECIFIC recruiter invited. Nullable because legacy
  // engagements (pre-person-level invites) only stored organizationId;
  // new rows always set this.
  invitedEmail   String?
  // User that claimed the invite. Set when the invited email matches an
  // existing User at invite time, or later when a PendingFirmInvite is
  // promoted to an engagement on login. Null for legacy rows.
  invitedUserId  String?
  status         String    @default("PENDING")
  message        String?
  jobId          String?
  invitedAt      DateTime  @default(now())
  respondedAt    DateTime?

  clientJob    ClientJob    @relation(fields: [clientJobId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  invitedUser  User?        @relation("InvitedUser", fields: [invitedUserId], references: [id])
  job          Job?         @relation(fields: [jobId], references: [id])

  // One invite per email per job. Legacy rows (null invitedEmail) are
  // exempt — Postgres treats NULLs as distinct — so the migration is safe.
  @@unique([clientJobId, invitedEmail])
  @@index([organizationId])
  @@index([invitedUserId])
  @@index([organizationId, status])
}

// ─── PENDING FIRM INVITES (email invites before firm registers) ───

model PendingFirmInvite {
  id          String   @id @default(cuid())
  email       String
  clientJobId String
  message     String?
  clientId    String
  createdAt   DateTime @default(now())

  clientJob ClientJob @relation(fields: [clientJobId], references: [id], onDelete: Cascade)

  @@index([email])
  @@unique([email, clientJobId])
}

// ─── BILLING ───

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  seats                Int                @default(1)
  // Complimentary / free-forever flag. Used for founding-team orgs,
  // partners, long-running test accounts — anyone we want to keep
  // unlocked without tying them to a Stripe subscription. When true,
  // subscription checks pass regardless of status/trial.
  isComp               Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

// ─── PASSWORD RESETS ───

model PasswordResetToken {
  id           String   @id @default(cuid())
  token        String   @unique
  userId       String?
  clientUserId String?
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([clientUserId])
  @@index([token])
}

// ─── INVITES ───

model UserInvite {
  id             String   @id @default(cuid())
  email          String
  name           String?
  token          String   @unique @default(cuid())
  role           UserRole @default(USER)
  organizationId String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([token])
  @@index([organizationId])
}
