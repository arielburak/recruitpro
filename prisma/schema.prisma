generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── MULTI-TENANCY ───

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  defaultStages String[] @default(["Sourced", "Contacted", "Submitted", "Interview", "Offer", "Placed"])

  users        User[]
  clients      Client[]
  candidates   Candidate[]
  contacts     Contact[]
  jobs         Job[]
  deals        Deal[]
  placements   Placement[]
  subscription Subscription?
  activities   Activity[]
  engagements  FirmEngagement[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  role           UserRole @default(RECRUITER)
  avatar         String?
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization          @relation(fields: [organizationId], references: [id])
  candidates     Candidate[]
  submissions    CandidateSubmission[] @relation("SubmittedBy")
  comments       Comment[]
  activities     Activity[]
  jobAssignments JobAssignment[]

  @@index([organizationId])
}

enum UserRole {
  ADMIN
  PARTNER
  RECRUITER
}

// ─── CLIENTS (Hiring Companies) ───

model Client {
  id             String   @id @default(cuid())
  name           String
  industry       String?
  website        String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  notes          String?
  isOffLimits    Boolean  @default(false)
  bdStatus       String?
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  jobs         Job[]
  clientUsers  ClientUser[]
  contacts     Contact[]
  deals        Deal[]
  placements   Placement[]
  portalTokens ClientPortalToken[]
  clientJobs   ClientJob[]

  @@index([organizationId])
}

// ─── CONTACTS (people at hiring companies) ───

model Contact {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  title          String?
  email          String?
  phone          String?
  linkedIn       String?
  isPrimary      Boolean  @default(false)
  notes          String?
  clientId       String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  jobs         Job[]        @relation("HiringManager")
  deals        Deal[]

  @@index([clientId])
  @@index([organizationId])
}

model ClientUser {
  id           String   @id @default(cuid())
  email        String
  name         String
  passwordHash String?
  clientId     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client     Client            @relation(fields: [clientId], references: [id])
  comments   Comment[]
  ratings    CandidateRating[]
  clientJobs ClientJob[]

  @@unique([email, clientId])
  @@index([clientId])
}

model ClientPortalToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  jobId     String?
  clientId  String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([token])
  @@index([clientId])
}

// ─── CANDIDATES ───

model Candidate {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  linkedIn       String?
  location       String?
  currentTitle   String?
  currentCompany String?
  currentSalary  Decimal?
  desiredSalary  Decimal?
  skills         String[] @default([])
  summary        String?
  source         String?
  isOffLimits    Boolean  @default(false)
  tags           String[] @default([])
  organizationId String
  ownerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id])
  owner        User                  @relation(fields: [ownerId], references: [id])
  submissions  CandidateSubmission[]
  documents    Document[]
  comments     Comment[]             @relation("CandidateComments")
  activities   Activity[]            @relation("CandidateActivities")

  @@index([organizationId])
  @@index([ownerId])
  @@index([organizationId, lastName, firstName])
}

// ─── JOBS / SEARCHES ───

model Job {
  id             String    @id @default(cuid())
  title          String
  description    String?
  status         JobStatus @default(OPEN)
  feeType        FeeType   @default(PERCENTAGE)
  feeAmount      Decimal?
  salary         String?
  location       String?
  clientId         String
  hiringManagerId  String?
  organizationId   String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  client         Client              @relation(fields: [clientId], references: [id])
  hiringManager  Contact?            @relation("HiringManager", fields: [hiringManagerId], references: [id])
  organization   Organization        @relation(fields: [organizationId], references: [id])
  stages         PipelineStage[]
  submissions    CandidateSubmission[]
  assignments    JobAssignment[]
  placements     Placement[]

  @@index([organizationId])
  @@index([clientId])
  @@index([organizationId, status])
}

enum JobStatus {
  OPEN
  ACTIVE
  ON_HOLD
  FILLED
  CLOSED
}

enum FeeType {
  PERCENTAGE
  FLAT
}

model JobAssignment {
  id     String @id @default(cuid())
  jobId  String
  userId String

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
}

// ─── PIPELINE ───

model PipelineStage {
  id    String @id @default(cuid())
  name  String
  order Int
  color String @default("#6366f1")
  jobId String

  job         Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  submissions CandidateSubmission[]

  @@unique([jobId, order])
  @@index([jobId])
}

model CandidateSubmission {
  id                 String   @id @default(cuid())
  candidateId        String
  jobId              String
  stageId            String
  submittedBy        String
  notes              String?
  isSharedWithClient Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  candidate Candidate       @relation(fields: [candidateId], references: [id])
  job       Job             @relation(fields: [jobId], references: [id])
  stage     PipelineStage   @relation(fields: [stageId], references: [id])
  submitter  User            @relation("SubmittedBy", fields: [submittedBy], references: [id])
  comments   Comment[]       @relation("SubmissionComments")
  ratings    CandidateRating[]
  placement  Placement?

  @@unique([candidateId, jobId])
  @@index([jobId, stageId])
}

model CandidateRating {
  id           String   @id @default(cuid())
  score        Int
  feedback     String?
  submissionId String
  clientUserId String
  createdAt    DateTime @default(now())

  submission CandidateSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  clientUser ClientUser          @relation(fields: [clientUserId], references: [id])

  @@unique([submissionId, clientUserId])
}

// ─── COMMENTS ───

model Comment {
  id           String      @id @default(cuid())
  content      String
  type         CommentType @default(INTERNAL)
  mentions     String[]    @default([])
  candidateId  String?
  submissionId String?
  userId       String?
  clientUserId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  candidate  Candidate?            @relation("CandidateComments", fields: [candidateId], references: [id])
  submission CandidateSubmission?  @relation("SubmissionComments", fields: [submissionId], references: [id])
  user       User?                 @relation(fields: [userId], references: [id])
  clientUser ClientUser?           @relation(fields: [clientUserId], references: [id])

  @@index([candidateId])
  @@index([submissionId])
}

enum CommentType {
  INTERNAL
  CLIENT_VISIBLE
}

// ─── DOCUMENTS ───

model Document {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String
  size        Int
  candidateId String
  uploadedBy  String
  createdAt   DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
}

// ─── ACTIVITIES ───

model Activity {
  id             String   @id @default(cuid())
  action         String
  description    String
  metadata       Json     @default("{}")
  userId         String?
  candidateId    String?
  organizationId String
  createdAt      DateTime @default(now())

  user         User?        @relation(fields: [userId], references: [id])
  candidate    Candidate?   @relation("CandidateActivities", fields: [candidateId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([candidateId])
}

// ─── DEALS (BD Pipeline) ───

model Deal {
  id             String     @id @default(cuid())
  title          String
  value          Decimal?
  probability    Int?       @default(50)
  stage          DealStage  @default(LEAD)
  expectedClose  DateTime?
  notes          String?
  clientId       String
  contactId      String?
  ownerId        String
  organizationId String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  client       Client       @relation(fields: [clientId], references: [id])
  contact      Contact?     @relation(fields: [contactId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, stage])
}

enum DealStage {
  LEAD
  QUALIFIED
  PITCHED
  NEGOTIATION
  WON
  LOST
}

// ─── PLACEMENTS ───

model Placement {
  id               String          @id @default(cuid())
  startDate        DateTime?
  feeAmount        Decimal?
  feePercentage    Decimal?
  salary           Decimal?
  invoiceStatus    InvoiceStatus   @default(DRAFT)
  guaranteePeriod  Int?            @default(90)
  guaranteeExpiry  DateTime?
  notes            String?
  submissionId     String          @unique
  jobId            String
  clientId         String
  organizationId   String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  submission   CandidateSubmission @relation(fields: [submissionId], references: [id])
  job          Job                 @relation(fields: [jobId], references: [id])
  client       Client              @relation(fields: [clientId], references: [id])
  organization Organization        @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, createdAt(sort: Desc)])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

// ─── CLIENT JOBS (posted by clients directly) ───

model ClientJob {
  id           String   @id @default(cuid())
  title        String
  description  String?
  requirements String?
  location     String?
  salaryRange  String?
  jobType      String   @default("Full-time")
  isRemote     Boolean  @default(false)
  status       String   @default("OPEN")
  clientId     String
  postedById   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client      Client           @relation(fields: [clientId], references: [id])
  postedBy    ClientUser       @relation(fields: [postedById], references: [id])
  engagements FirmEngagement[]

  @@index([clientId])
  @@index([status])
}

// ─── FIRM ENGAGEMENTS (links client jobs to recruiting firms) ───

model FirmEngagement {
  id             String    @id @default(cuid())
  clientJobId    String
  organizationId String
  status         String    @default("PENDING")
  message        String?
  jobId          String?
  invitedAt      DateTime  @default(now())
  respondedAt    DateTime?

  clientJob    ClientJob    @relation(fields: [clientJobId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([clientJobId, organizationId])
  @@index([organizationId])
  @@index([organizationId, status])
}

// ─── BILLING ───

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  seats                Int                @default(1)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

// ─── PASSWORD RESETS ───

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ─── INVITES ───

model UserInvite {
  id             String   @id @default(cuid())
  email          String
  token          String   @unique @default(cuid())
  role           UserRole @default(RECRUITER)
  organizationId String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([token])
  @@index([organizationId])
}
