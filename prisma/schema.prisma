generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── MULTI-TENANCY ───

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  defaultStages String[] @default(["Sourced", "Contacted", "Submitted", "Interview", "Offer", "Placed"])

  users        User[]
  clients      Client[]
  candidates   Candidate[]
  jobs         Job[]
  subscription Subscription?
  activities   Activity[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  role           UserRole @default(RECRUITER)
  avatar         String?
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization          @relation(fields: [organizationId], references: [id])
  candidates     Candidate[]
  submissions    CandidateSubmission[] @relation("SubmittedBy")
  comments       Comment[]
  activities     Activity[]
  jobAssignments JobAssignment[]

  @@index([organizationId])
}

enum UserRole {
  ADMIN
  RECRUITER
}

// ─── CLIENTS (Hiring Companies) ───

model Client {
  id             String   @id @default(cuid())
  name           String
  industry       String?
  website        String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  notes          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  jobs         Job[]
  clientUsers  ClientUser[]

  @@index([organizationId])
}

model ClientUser {
  id           String   @id @default(cuid())
  email        String
  name         String
  passwordHash String?
  clientId     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client   Client            @relation(fields: [clientId], references: [id])
  comments Comment[]
  ratings  CandidateRating[]

  @@unique([email, clientId])
  @@index([clientId])
}

model ClientPortalToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  jobId     String?
  clientId  String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@index([token])
}

// ─── CANDIDATES ───

model Candidate {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  linkedIn       String?
  location       String?
  currentTitle   String?
  currentCompany String?
  currentSalary  Decimal?
  desiredSalary  Decimal?
  skills         String[] @default([])
  summary        String?
  source         String?
  organizationId String
  ownerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id])
  owner        User                  @relation(fields: [ownerId], references: [id])
  submissions  CandidateSubmission[]
  documents    Document[]
  comments     Comment[]             @relation("CandidateComments")
  activities   Activity[]            @relation("CandidateActivities")

  @@index([organizationId])
  @@index([ownerId])
  @@index([organizationId, lastName, firstName])
}

// ─── JOBS / SEARCHES ───

model Job {
  id             String    @id @default(cuid())
  title          String
  description    String?
  status         JobStatus @default(OPEN)
  feeType        FeeType   @default(PERCENTAGE)
  feeAmount      Decimal?
  salary         String?
  location       String?
  clientId       String
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client       Client              @relation(fields: [clientId], references: [id])
  organization Organization        @relation(fields: [organizationId], references: [id])
  stages       PipelineStage[]
  submissions  CandidateSubmission[]
  assignments  JobAssignment[]

  @@index([organizationId])
  @@index([clientId])
  @@index([organizationId, status])
}

enum JobStatus {
  OPEN
  ACTIVE
  ON_HOLD
  FILLED
  CLOSED
}

enum FeeType {
  PERCENTAGE
  FLAT
}

model JobAssignment {
  id     String @id @default(cuid())
  jobId  String
  userId String

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
}

// ─── PIPELINE ───

model PipelineStage {
  id    String @id @default(cuid())
  name  String
  order Int
  color String @default("#6366f1")
  jobId String

  job         Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  submissions CandidateSubmission[]

  @@unique([jobId, order])
  @@index([jobId])
}

model CandidateSubmission {
  id                 String   @id @default(cuid())
  candidateId        String
  jobId              String
  stageId            String
  submittedBy        String
  notes              String?
  isSharedWithClient Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  candidate Candidate       @relation(fields: [candidateId], references: [id])
  job       Job             @relation(fields: [jobId], references: [id])
  stage     PipelineStage   @relation(fields: [stageId], references: [id])
  submitter User            @relation("SubmittedBy", fields: [submittedBy], references: [id])
  comments  Comment[]       @relation("SubmissionComments")
  ratings   CandidateRating[]

  @@unique([candidateId, jobId])
  @@index([jobId, stageId])
}

model CandidateRating {
  id           String   @id @default(cuid())
  score        Int
  feedback     String?
  submissionId String
  clientUserId String
  createdAt    DateTime @default(now())

  submission CandidateSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  clientUser ClientUser          @relation(fields: [clientUserId], references: [id])

  @@unique([submissionId, clientUserId])
}

// ─── COMMENTS ───

model Comment {
  id           String      @id @default(cuid())
  content      String
  type         CommentType @default(INTERNAL)
  candidateId  String?
  submissionId String?
  userId       String?
  clientUserId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  candidate  Candidate?            @relation("CandidateComments", fields: [candidateId], references: [id])
  submission CandidateSubmission?  @relation("SubmissionComments", fields: [submissionId], references: [id])
  user       User?                 @relation(fields: [userId], references: [id])
  clientUser ClientUser?           @relation(fields: [clientUserId], references: [id])

  @@index([candidateId])
  @@index([submissionId])
}

enum CommentType {
  INTERNAL
  CLIENT_VISIBLE
}

// ─── DOCUMENTS ───

model Document {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String
  size        Int
  candidateId String
  uploadedBy  String
  createdAt   DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
}

// ─── ACTIVITIES ───

model Activity {
  id             String   @id @default(cuid())
  action         String
  description    String
  metadata       Json     @default("{}")
  userId         String?
  candidateId    String?
  organizationId String
  createdAt      DateTime @default(now())

  user         User?        @relation(fields: [userId], references: [id])
  candidate    Candidate?   @relation("CandidateActivities", fields: [candidateId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([candidateId])
}

// ─── BILLING ───

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  seats                Int                @default(1)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

// ─── PASSWORD RESETS ───

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ─── INVITES ───

model UserInvite {
  id             String   @id @default(cuid())
  email          String
  token          String   @unique @default(cuid())
  role           UserRole @default(RECRUITER)
  organizationId String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([token])
  @@index([organizationId])
}
